# Copy this file to .env and fill in your keys
# Never commit .env to GitHub

ODDS_API_KEY=your_odds_api_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# Optional - only needed for Westgate SuperBook
# OPTICODDS_KEY=your_opticodds_key_here


# ─────────────────────────────────────────
# SIGN-IN FEATURE (added for user accounts + email)
# ─────────────────────────────────────────

# Resend (email delivery) — from resend.com > API keys. Starts with "re_".
RESEND_API_KEY=your_resend_api_key_here

# The "From" address on outgoing emails.
# Use onboarding@resend.dev for testing (only reaches YOUR account email),
# then switch to your verified domain, e.g. "PropJunkie <noreply@propjunkie.app>".
RESEND_FROM_EMAIL=onboarding@resend.dev

# Database. Railway provides DATABASE_URL automatically in production.
# Leave blank locally to use a SQLite file for development.
DATABASE_URL=

# Secret key for signing login sessions + email links. Generate a strong one:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_random_secret_here

# Minimum signup age (legal age gate)
MIN_AGE=21
